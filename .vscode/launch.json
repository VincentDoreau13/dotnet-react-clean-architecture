{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Back — ShopApi (Development)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "back: build",
      "program": "${workspaceFolder}/src/back/bin/Debug/net10.0/ShopApi.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/back",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7080;http://localhost:5080",
        "UseInMemoryDatabase": "true"
      }
    },
    {
      "name": "Attach to Process",
      "type": "coreclr",
      "request": "attach"
    }
  ]
}
