{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Back — ShopApi (Development)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "back: build",
      "program": "${workspaceFolder}/src/back/bin/Debug/net10.0/ShopApi.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/back",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7080;http://localhost:5080",
        "UseInMemoryDatabase": "true"
      }
    },
    {
      "name": "Front — Dev Server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/src/front",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "Local:.*http://localhost:(\\d+)",
        "uriFormat": "http://localhost:%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Attach to Process",
      "type": "coreclr",
      "request": "attach"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": ["Back — ShopApi (Development)", "Front — Dev Server"],
      "stopAll": true
    }
  ]
}
